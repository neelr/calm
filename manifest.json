  "default_locale": "en",
  "description": "Clean up YouTube and Twitter/X, add Spotify playback speed, and include a uBOL-based MV3 adblock core.",
  "host_permissions": [
    "<all_urls>"
  ],
  "incognito": "split",
  "manifest_version": 3,
  "minimum_chrome_version": "122.0",
  "name": "Calm Feed",
  "options_page": "adblock/runtime/dashboard.html",
  "permissions": [
    "declarativeNetRequest",
    "offscreen",
    "scripting",
    "storage",
    "userScripts",
    "tabs",
    "cookies"
  ],
  "short_name": "Calm Feed",
  "storage": {
    "managed_schema": "adblock/runtime/managed_storage.json"
  },
  "version": "1.0.0",
  "web_accessible_resources": [
    {
      "resources": [
        "adblock/runtime/strictblock.html"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "adblock/runtime/zapper-ui.html"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "adblock/runtime/picker-ui.html"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "adblock/runtime/unpicker-ui.html"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "adblock/runtime/web_accessible_resources/noop.js",
        "adblock/runtime/web_accessible_resources/amazon_apstag.js",
        "adblock/runtime/web_accessible_resources/google-ima.js",
        "adblock/runtime/web_accessible_resources/fingerprint2.js",
        "adblock/runtime/web_accessible_resources/adthrive_abd.js",
        "adblock/runtime/web_accessible_resources/noop.txt",
        "adblock/runtime/web_accessible_resources/1x1.gif",
        "adblock/runtime/web_accessible_resources/noop.css",
        "adblock/runtime/web_accessible_resources/32x32.png",
        "adblock/runtime/web_accessible_resources/2x2.png",
        "adblock/runtime/web_accessible_resources/noop.html",
        "adblock/runtime/web_accessible_resources/amazon_ads.js",
        "adblock/runtime/web_accessible_resources/googletagservices_gpt.js",
        "adblock/runtime/web_accessible_resources/google-analytics_analytics.js",
        "adblock/runtime/web_accessible_resources/nofab.js",
        "adblock/runtime/web_accessible_resources/hd-main.js",
        "adblock/runtime/web_accessible_resources/popads.js",
        "adblock/runtime/web_accessible_resources/googlesyndication_adsbygoogle.js",
        "adblock/runtime/web_accessible_resources/prebid-ads.js",
        "adblock/runtime/web_accessible_resources/doubleclick_instream_ad_status.js",
        "adblock/runtime/web_accessible_resources/google-analytics_cx_api.js",
        "adblock/runtime/web_accessible_resources/scorecardresearch_beacon.js",
        "adblock/runtime/web_accessible_resources/google-analytics_ga.js",
        "adblock/runtime/web_accessible_resources/outbrain-widget.js",
        "adblock/runtime/web_accessible_resources/fingerprint3.js",
        "adblock/runtime/web_accessible_resources/noop-vmap1.xml",
        "adblock/runtime/web_accessible_resources/empty",
        "adblock/runtime/web_accessible_resources/noop-vast3.xml",
        "adblock/runtime/web_accessible_resources/noop-0.1s.mp3",
        "adblock/runtime/web_accessible_resources/noop-vast2.xml",
        "adblock/runtime/web_accessible_resources/noop-1s.mp4",
        "adblock/runtime/web_accessible_resources/nobab2.js",
        "adblock/runtime/web_accessible_resources/nitropay_ads.js",
        "adblock/runtime/web_accessible_resources/chartbeat.js",
        "adblock/runtime/web_accessible_resources/noop.json",
        "adblock/runtime/web_accessible_resources/noeval-silent.js",
        "adblock/runtime/web_accessible_resources/click2load.html"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "x/page-script.js"
      ],
      "matches": [
        "https://twitter.com/*",
        "https://www.twitter.com/*",
        "https://x.com/*",
        "https://www.x.com/*"
      ]
    },
    {
      "resources": [
        "spotifyplayback/page-script.js"
      ],
      "matches": [
        "https://open.spotify.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "videospeed/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://open.spotify.com/*"
      ],
      "js": [
        "spotifyplayback/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "youtube/content.js"
      ],
      "css": [
        "youtube/styles.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://twitter.com/*",
        "https://www.twitter.com/*",
        "https://x.com/*",
        "https://www.x.com/*"
      ],
      "js": [
        "x/inject.js",
        "x/content.js"
      ],
      "css": [
        "x/styles.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "http://localhost/*",
        "https://localhost/*",
        "https://www.messenger.com/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://calendar.google.com/*"
      ],
      "js": [
        "curius/content.js"
      ],
      "css": [
        "curius/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://curius.app/*",
        "https://www.curius.app/*"
      ],
      "js": [
        "curius/site-export.js"
      ],
      "css": [
        "curius/site-export.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
